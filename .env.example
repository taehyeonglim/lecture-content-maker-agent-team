# lecture-content-maker-agent-team — 환경변수 예시
#
# 실제 사용 시 이 파일을 `.env`로 복사 후 값 채워넣기:
#   cp .env.example .env
#
# .env 는 .gitignore 에 포함되어 있어 GitHub에 올라가지 않습니다.
# scripts/*.sh 는 모두 `set -a; source .env; set +a` 패턴으로 로드합니다.

# ─── OpenAI / Codex CLI ───
# Codex CLI는 OAuth 인증(`codex login`)을 우선 사용하므로 일반적으로 불필요.
# OAuth가 실패하거나 wrapper 호출이 필요할 때만 설정.
OPENAI_API_KEY=

# gpt-image-gen 호출용 (보통 OPENAI_API_KEY와 동일)
GPT_IMAGE_GEN_KEY=

# ─── Anthropic / Claude Code ───
# Claude Code도 OAuth(`claude /login`)을 우선 사용. fallback 시에만.
ANTHROPIC_API_KEY=

# ─── Google Slides API (User OAuth, PI 계정) ───
# Google Cloud Console > APIs & Services > Credentials 에서 OAuth 2.0 Client ID 생성.
# 1회 인증 후 refresh token을 발급받아 저장 (별도 OAuth flow 스크립트로 획득).
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# ─── Wikimedia Commons API ───
# 익명 호출 가능하지만 User-Agent 헤더는 매너상 필수.
# 형식: "<app-name>/<version> (<contact-email>)"
WIKIMEDIA_USER_AGENT=lecture-content-maker/0.1 (limtaehyeong@gmail.com)

# ─── 비용 추적 (선택) ───
# gpt-5.5 모델 단가(USD per 1M tokens). spike 단계에서는 placeholder.
# 정확한 값은 OpenAI 공식 가격표 참고.
COST_PER_1M_INPUT_GPT55=0.00
COST_PER_1M_OUTPUT_GPT55=0.00
COST_PER_1M_INPUT_GPT55_XHIGH=0.00
COST_PER_1M_OUTPUT_GPT55_XHIGH=0.00
COST_PER_GPT_IMAGE=0.00
